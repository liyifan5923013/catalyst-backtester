# Copy to terraform.tfvars (gitignored) and fill in. The DB password can also be
# supplied out-of-band via: export TF_VAR_db_password=...
aws_region  = "us-east-1"
project     = "catalyst-backtester"

db_username = "catalyst"
db_password = "change-me-strong-password"
db_name     = "catalyst"

# Optional sizing overrides:
# db_instance_class = "db.t4g.micro"
# apprunner_cpu     = "1024"
# apprunner_memory  = "2048"
# image_tag         = "latest"

# Optional scheduled data pre-warm (read-through still fetches on demand):
# prewarm_enabled        = true
# prewarm_interval_hours = 24
